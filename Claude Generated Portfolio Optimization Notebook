    "    \"\"\"Solve for minimum-variance weights that achieve a specific return target.\"\"\"\n",
    "    cons = [\n",
    "        {'type': 'eq', 'fun': check_sum},\n",
    "        {'type': 'eq', 'fun': lambda w: float(np.dot(w, exp_returns.values)) - target_return},\n",
