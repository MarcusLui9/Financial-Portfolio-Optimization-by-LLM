    "        x0=eq_weights,\n",
    "        method='SLSQP',\n",
    "        bounds=bounds,\n",
    "        constraints=cons,\n",
    "        options={'ftol': 1e-13, 'maxiter': 3_000}\n",
    "    )\n",
    "    return res\n",
